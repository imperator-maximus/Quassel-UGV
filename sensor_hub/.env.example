# Quassel UGV Sensor Hub - Environment Variables
# 
# WICHTIG: Diese Datei ist ein Template!
# Kopiere diese Datei zu .env und fülle deine Credentials ein:
#   cp .env.example .env
#
# Die .env Datei wird NICHT in Git committed (siehe .gitignore)
# Sie enthält sensitive Daten wie Passwörter und API-Keys!

# ============================================================================
# NTRIP/RTK Konfiguration
# ============================================================================
# NTRIP Server für RTK-Korrekturdaten
NTRIP_HOST=openrtk-mv.de
NTRIP_PORT=2101
NTRIP_MOUNTPOINT=openrtk_mv_2G

# NTRIP Authentifizierung
# ⚠️ NIEMALS in Git committen!
NTRIP_USERNAME=your_username_here
NTRIP_PASSWORD=your_password_here

# ============================================================================
# Weitere Konfiguration (optional)
# ============================================================================
# GPS Port (default: USB by-id Wildcard für FTDI/UM982)
# GPS_PORT=/dev/serial/by-id/usb-FTDI_FT231X_USB_UART_*

# NTRIP im Sensor-Hub aktivieren/deaktivieren
# NTRIP_ENABLED=1

# IMU im Sensor-Hub aktivieren/deaktivieren
# IMU_ENABLED=1
# IMU_TYPE=witmotion
# IMU_PORT=/dev/serial/by-id/usb-1a86_USB_Serial-if00-port0
# IMU_BAUDRATE=9600
# IMU_TIMEOUT=1.0

# Web Port (default: 8080)
# WEB_PORT=8080

# Log Level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

